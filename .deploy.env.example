# Deploy credentials template.
#   1. Copy this file to  .deploy.env   (same directory)
#   2. Fill in SFTP_PASS and confirm the values below.
#   3. .deploy.env is git-ignored — NEVER commit it or paste the password anywhere shared.

SFTP_HOST=access-5019418900.webspace-host.com
SFTP_PORT=22
SFTP_USER=a1942432
SFTP_PASS=your-sftp-password-here

# Remote target directory. "." = the directory you land in after SFTP login
# (usually the web root on webspace hosts). Change if your site lives in a subfolder.
REMOTE_DIR=.
